# ═══════════════════════════════════════════════════════════════════
# Budget Optimizer API Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── AI Services (choose one or both for automatic fallback) ──────
# Google Gemini API (FREE - 1,500 requests/day)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (PAID - ~$0.0001 per request with gpt-4o-mini)
# Get your key at: https://platform.openai.com/api-keys
# Only needed if you want fallback when Gemini rate limit hits
OPENAI_API_KEY=your_openai_api_key_here

# ── How it works ─────────────────────────────────────────────────
# 1. If both keys are set: Tries Gemini first (free), falls back to OpenAI if needed
# 2. If only Gemini is set: Uses Gemini only
# 3. If only OpenAI is set: Uses OpenAI only
# 4. If neither is set: AI insights feature disabled (budget analysis still works)

# ── Recommendations ──������────────────────────────────────────────
# For students/development: Use only GEMINI_API_KEY (free)
# For production: Set both keys for 99.9% uptime

# ── MongoDB Connection (for Node.js backend) ─────────────────────
# Only needed if you're using the Node.js API
# MONGO=your_mongodb_connection_string

# ── Other (Leave as default) ─────────────────────────────────────
# PORT=5002

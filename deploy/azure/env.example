# Azure Environment Configuration
# Set these as GitHub repository secrets

# Azure Credentials (Service Principal)
# Get this by running: az ad sp create-for-rbac --name "unifinder-github-actions" --role contributor --scopes /subscriptions/{subscription-id}/resourceGroups/{resource-group} --sdk-auth
AZURE_CREDENTIALS=<paste-service-principal-json>

# Azure Configuration
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=unifinder-rg
AZURE_LOCATION=eastus
ACR_NAME=unifinderacr  # Must be globally unique, lowercase, alphanumeric only

# Application Secrets (GitHub Secrets)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=<your-jwt-secret>
OPENAI_API_KEY=<your-openai-api-key>
GEMINI_API_KEY=<your-gemini-api-key>

# Environment
ENVIRONMENT=prod  # or dev, staging

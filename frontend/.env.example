# Frontend env (CRA)
# Direct microservice base URLs
# API base for Express endpoints such as /api/career-profiles.
# In production this can be omitted when the frontend and backend share an origin.
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_BACKEND_URL=http://localhost:5000
REACT_APP_DEGREE_SERVICE_URL=http://127.0.0.1:5001
REACT_APP_RECOMMENDATION_SERVICE_URL=http://127.0.0.1:5003
REACT_APP_BUDGET_SERVICE_URL=http://127.0.0.1:5002
REACT_APP_CAREER_SERVICE_URL=http://127.0.0.1:5004
REACT_APP_SCHOLARSHIP_MATCHER_URL=http://127.0.0.1:5005
# Backward-compatible alias (optional)
REACT_APP_SCHOLARSHIP_SERVICE_URL=http://127.0.0.1:5005
